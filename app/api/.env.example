DATABASE_URL=mysql+pymysql://usuario:senha@host:porta/nome_banco

# Em desenvolvimento local, use apenas a origem do Vite.
# Em producao, o valor real e configurado via `fly secrets set`
# diretamente no Fly.io (nunca commitado), e deve incluir o dominio
# de producao do frontend na Vercel separado por virgula, ex:
# CORS_ORIGINS=https://seu-dominio.vercel.app,http://localhost:5173
CORS_ORIGINS=http://localhost:5173
